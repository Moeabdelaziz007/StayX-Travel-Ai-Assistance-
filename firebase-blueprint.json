{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile containing settings and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "voiceTone": { "type": "string", "enum": ["Friendly", "Professional"] },
        "loyaltyLevel": { "type": "string", "enum": ["Silver", "Gold", "Platinum"] }
      },
      "required": ["uid", "displayName"]
    },
    "Trip": {
      "title": "Trip",
      "description": "A trip itinerary.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "destination": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "status": { "type": "string" }
      },
      "required": ["userId", "destination"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Trip itinerary documents."
    }
  }
}
